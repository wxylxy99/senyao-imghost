# Cloudflare Configuration
# Copy this file to .env and .env.production

# API Base URL (leave empty for relative paths when Worker serves frontend)
VITE_API_BASE=

# Cloudflare Account ID
# CF_ACCOUNT_ID=your-account-id

# R2 Bucket Name
# IMG_BUCKET=imghost

# Custom Domain (optional)
# CUSTOM_DOMAIN=https://img.your-domain.com
